{
  "name": "px-react-copy-to-clipboard-hook",
  "version": "1.0.1",
  "type": "module",
  "workspaces": [
    "example"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "keywords": [
    "react",
    "hook",
    "hooks",
    "clipboard",
    "copy",
    "copy-to-clipboard",
